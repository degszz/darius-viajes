---
import { slides, waLink } from '../data/viajes';
---

<section class="mt-[68px] relative h-[calc(100vh-68px)] min-h-[540px] max-h-[760px] overflow-hidden max-[640px]:max-h-[600px]">
  <div class="flex h-full transition-transform duration-700 ease-[cubic-bezier(.4,0,.2,1)]" id="slides">
    {slides.map((slide) => (
      <div
        class="min-w-full relative bg-cover bg-center"
        style={`background-image: url('${slide.imagen}')`}
      >
        <div class="absolute inset-0 bg-[linear-gradient(105deg,rgba(0,28,84,.75)_38%,rgba(0,28,84,.15)_80%)]"></div>
        <div class="absolute top-1/2 left-[8vw] -translate-y-1/2 max-w-[580px] text-white">
          <span class="inline-block bg-teal text-white text-[.72rem] font-bold tracking-[.16em] uppercase py-1 px-[14px] rounded-[3px] mb-[18px]">{slide.etiqueta}</span>
          <h1 class="font-serif text-[clamp(2.2rem,5vw,3.8rem)] leading-[1.12] font-bold mb-[10px]">
            {slide.titulo}<br/><em class="italic text-teal-light font-serif">{slide.tituloDestacado}</em>
          </h1>
          <p class="text-[1.05rem] opacity-88 leading-relaxed mb-8 max-w-[460px]">{slide.subtitulo}</p>
          <div class="flex gap-[14px] flex-wrap">
            <a href="#promos" class="inline-flex items-center gap-2 bg-teal text-white py-[13px] px-7 rounded-full text-[.92rem] font-bold no-underline transition-colors duration-200 hover:bg-teal-light hover:-translate-y-0.5">
              Ver Promociones &rarr;
            </a>
            <a href={waLink(slide.textoWhatsApp)} target="_blank" class="inline-flex items-center gap-2 border-2 border-white/75 text-white py-[11px] px-[26px] rounded-full text-[.92rem] font-semibold no-underline transition-colors duration-200 backdrop-blur-sm bg-white/8 hover:bg-white/18 hover:border-white">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.134.558 4.136 1.535 5.875L0 24l6.312-1.507A11.935 11.935 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-5.017-1.376l-.36-.213-3.728.89.936-3.617-.234-.373A9.77 9.77 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"/></svg>
              Consultar Ahora
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <button id="prevBtn" aria-label="Anterior" class="absolute top-1/2 -translate-y-1/2 w-[46px] h-[46px] rounded-full bg-white/18 backdrop-blur-md border-[1.5px] border-white/40 text-white text-[1.1rem] cursor-pointer flex items-center justify-center z-10 left-6 transition-colors duration-200 hover:bg-teal">
    &#8592;
  </button>
  <button id="nextBtn" aria-label="Siguiente" class="absolute top-1/2 -translate-y-1/2 w-[46px] h-[46px] rounded-full bg-white/18 backdrop-blur-md border-[1.5px] border-white/40 text-white text-[1.1rem] cursor-pointer flex items-center justify-center z-10 right-6 transition-colors duration-200 hover:bg-teal">
    &#8594;
  </button>

  <div id="dots" class="absolute bottom-7 left-1/2 -translate-x-1/2 flex gap-[10px] z-10">
    {slides.map((_, i) => (
      <span class={`dot w-[10px] h-[10px] rounded-full bg-white/45 cursor-pointer transition-all duration-200 ${i === 0 ? 'active bg-teal-light! scale-130' : ''}`} data-i={i}></span>
    ))}
  </div>
</section>

<script define:vars={{ total: slides.length }}>
  var slidesEl = document.getElementById('slides');
  var dots = document.querySelectorAll('.dot');
  var current = 0;
  var timer;

  function goTo(n) {
    current = ((n % total) + total) % total;
    slidesEl.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function (d, i) {
      if (i === current) {
        d.classList.add('active', 'bg-teal-light!', 'scale-130');
      } else {
        d.classList.remove('active', 'bg-teal-light!', 'scale-130');
      }
    });
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  function startAuto() {
    clearInterval(timer);
    timer = setInterval(next, 5000);
  }

  document.getElementById('nextBtn').addEventListener('click', function () { next(); startAuto(); });
  document.getElementById('prevBtn').addEventListener('click', function () { prev(); startAuto(); });

  dots.forEach(function (d) {
    d.addEventListener('click', function () {
      goTo(parseInt(d.getAttribute('data-i'), 10));
      startAuto();
    });
  });

  var startX = 0;
  slidesEl.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; });
  slidesEl.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 50) {
      if (dx < 0) next();
      else prev();
      startAuto();
    }
  });

  startAuto();
</script>
