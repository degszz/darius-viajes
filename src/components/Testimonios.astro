<section class="py-20 px-[5vw] bg-white">
  <div class="text-center mb-11">
    <h2 class="text-[clamp(1.5rem,3vw,2.1rem)] font-bold text-navy tracking-[.04em] uppercase">Lo que dicen nuestros viajeros</h2>
    <span class="block w-[52px] h-[3px] rounded-[2px] mx-auto mt-[10px]" style="background: linear-gradient(90deg, #0EA5A0, #F0B429)"></span>
  </div>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-6">
    <div class="bg-offwhite rounded-[14px] p-[28px_24px] border-l-[4px] border-teal shadow-[0_2px_12px_rgba(11,37,69,.07)]">
      <div class="flex gap-[3px] mb-[14px]">
        {[1,2,3,4,5].map(() => (
          <svg viewBox="0 0 24 24" class="w-4 h-4 fill-gold"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        ))}
      </div>
      <blockquote class="text-[.88rem] text-navy leading-relaxed italic mb-5">Increíble experiencia en Punta Cana. Todo perfecto, excelente atención antes y durante el viaje.</blockquote>
      <div class="flex items-center gap-3">
        <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="Mariana S." class="w-11 h-11 rounded-full object-cover border-2 border-teal" />
        <strong class="text-[.88rem] text-teal font-semibold">Mariana S.</strong>
      </div>
    </div>

    <div class="bg-offwhite rounded-[14px] p-[28px_24px] border-l-[4px] border-teal shadow-[0_2px_12px_rgba(11,37,69,.07)]">
      <div class="flex gap-[3px] mb-[14px]">
        {[1,2,3,4,5].map(() => (
          <svg viewBox="0 0 24 24" class="w-4 h-4 fill-gold"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        ))}
      </div>
      <blockquote class="text-[.88rem] text-navy leading-relaxed italic mb-5">El crucero fue espectacular. La organización y la atención de Darius, impecables. Ya estamos planeando el próximo.</blockquote>
      <div class="flex items-center gap-3">
        <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Fernando G." class="w-11 h-11 rounded-full object-cover border-2 border-teal" />
        <strong class="text-[.88rem] text-teal font-semibold">Fernando G.</strong>
      </div>
    </div>

    <div class="bg-offwhite rounded-[14px] p-[28px_24px] border-l-[4px] border-teal shadow-[0_2px_12px_rgba(11,37,69,.07)]">
      <div class="flex gap-[3px] mb-[14px]">
        {[1,2,3,4,5].map(() => (
          <svg viewBox="0 0 24 24" class="w-4 h-4 fill-gold"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        ))}
      </div>
      <blockquote class="text-[.88rem] text-navy leading-relaxed italic mb-5">Bariloche es hermoso y todo estuvo según lo acordado. Volveremos a viajar con ustedes. ¡Muchas gracias!</blockquote>
      <div class="flex items-center gap-3">
        <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="Laura M." class="w-11 h-11 rounded-full object-cover border-2 border-teal" />
        <strong class="text-[.88rem] text-teal font-semibold">Laura M.</strong>
      </div>
    </div>
  </div>
</section>
