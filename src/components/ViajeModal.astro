---
import { destinos, waLink } from '../data/viajes';
---

<div id="modal-overlay" class="hidden fixed inset-0 z-300 bg-navy/60 backdrop-blur-sm flex items-center justify-center p-5">
  <div id="modal-content" class="bg-white rounded-2xl max-w-[620px] w-full max-h-[90vh] overflow-y-auto shadow-[0_20px_60px_rgba(0,28,84,.3)] relative">
    <button id="modal-close" class="absolute top-4 right-4 w-9 h-9 rounded-full bg-navy/10 border-none cursor-pointer flex items-center justify-center text-navy text-lg transition-colors hover:bg-navy/20 z-10" aria-label="Cerrar">&times;</button>

    <div id="modal-image" class="w-full h-[240px] bg-cover bg-center rounded-t-2xl"></div>

    <div class="p-[28px_24px]">
      <span id="modal-categoria" class="inline-block bg-teal/10 text-teal text-[.72rem] font-bold tracking-[.12em] uppercase py-1 px-3 rounded-[3px] mb-3"></span>
      <h2 id="modal-titulo" class="font-serif text-[clamp(1.4rem,3vw,1.8rem)] font-bold text-navy mb-3"></h2>
      <p id="modal-descripcion" class="text-[.9rem] text-gray-custom leading-relaxed mb-6"></p>

      <div class="border-t border-navy/10 pt-5 flex items-center justify-between flex-wrap gap-4">
        <div>
          <span class="text-[.7rem] uppercase tracking-[.1em] text-gray-custom">Precio desde</span>
          <strong id="modal-precio" class="block text-[1.6rem] font-bold text-teal"></strong>
        </div>
        <a id="modal-wa" href="#" target="_blank" class="inline-flex items-center gap-2 bg-wa text-white py-3 px-6 rounded-full text-[.9rem] font-semibold no-underline transition-transform duration-200 shadow-[0_4px_14px_rgba(37,211,102,.35)] hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(37,211,102,.45)]">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.134.558 4.136 1.535 5.875L0 24l6.312-1.507A11.935 11.935 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-5.017-1.376l-.36-.213-3.728.89.936-3.617-.234-.373A9.77 9.77 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"/></svg>
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</div>

<script define:vars={{
  viajesData: JSON.stringify(destinos.map(d => ({
    id: d.id,
    nombre: d.nombre,
    categoria: d.categoria,
    imagen: d.imagen,
    descripcionCorta: d.descripcionCorta,
    descripcionLarga: d.descripcionLarga,
    precio: d.precio,
    textoWhatsApp: d.textoWhatsApp,
  }))),
  waNumero: "542226689720"
}}>
  const viajesData = JSON.parse(viajesData);
  const waNumero2 = waNumero;
  function buildWALink(texto) {
    return `https://wa.me/${waNumero2}?text=${encodeURIComponent(texto)}`;
  }

  const overlay = document.getElementById('modal-overlay');
  const modalImage = document.getElementById('modal-image');
  const modalCategoria = document.getElementById('modal-categoria');
  const modalTitulo = document.getElementById('modal-titulo');
  const modalDescripcion = document.getElementById('modal-descripcion');
  const modalPrecio = document.getElementById('modal-precio');
  const modalWa = document.getElementById('modal-wa');

  function openModal(viajeId) {
    var viaje = viajesData.find(function(v) { return v.id === viajeId; });
    if (!viaje) {
      viaje = (window._viajesModalData || []).find(function(v) { return v.id === viajeId; });
    }
    if (!viaje) return;

    modalImage.style.backgroundImage = 'url(\'' + viaje.imagen + '\')';
    modalCategoria.textContent = viaje.categoria;
    modalTitulo.textContent = viaje.nombre;
    modalDescripcion.textContent = viaje.descripcionLarga;
    modalPrecio.textContent = viaje.precio;
    modalWa.href = buildWALink(viaje.textoWhatsApp);

    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('modal-close').addEventListener('click', closeModal);

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !overlay.classList.contains('hidden')) closeModal();
  });

  document.addEventListener('click', function(e) {
    var target = e.target;
    var trigger = target.closest('[data-modal-viaje]');
    if (trigger) {
      var viajeId = trigger.getAttribute('data-modal-viaje');
      if (viajeId) openModal(viajeId);
    }
  });
</script>
